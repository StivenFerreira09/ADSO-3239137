-- =========================
-- BASE DE DATOS
-- =========================
CREATE DATABASE IF NOT EXISTS sistema_db;
USE sistema_db;

-- =========================
-- TABLAS
-- =========================

CREATE TABLE continente (
id_continente INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50) NOT NULL,
descripcion VARCHAR(100)
);

CREATE TABLE pais (
id_pais INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50) NOT NULL,
descripcion VARCHAR(100),
continente_id INT NOT NULL,
FOREIGN KEY (continente_id) REFERENCES continente(id_continente)
);

CREATE TABLE departamento (
id_departamento INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50) NOT NULL,
descripcion VARCHAR(100),
pais_id INT NOT NULL,
FOREIGN KEY (pais_id) REFERENCES pais(id_pais)
);

CREATE TABLE ciudad (
id_ciudad INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50) NOT NULL,
descripcion VARCHAR(100),
departamento_id INT NOT NULL,
FOREIGN KEY (departamento_id) REFERENCES departamento(id_departamento)
);

CREATE TABLE barrio (
id_barrio INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50) NOT NULL,
descripcion VARCHAR(100),
codigo_postal VARCHAR(20),
ciudad_id INT NOT NULL,
FOREIGN KEY (ciudad_id) REFERENCES ciudad(id_ciudad)
);

CREATE TABLE rol (
id_rol INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50),
permiso VARCHAR(50)
);

CREATE TABLE persona (
id_persona INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50),
barrio_id INT,
FOREIGN KEY (barrio_id) REFERENCES barrio(id_barrio)
);

CREATE TABLE usuario (
id_usuario INT AUTO_INCREMENT PRIMARY KEY,
username VARCHAR(50),
password VARCHAR(255),
persona_id INT,
rol_id INT,
FOREIGN KEY (persona_id) REFERENCES persona(id_persona),
FOREIGN KEY (rol_id) REFERENCES rol(id_rol)
);

CREATE TABLE categoria (
id_categoria INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50)
);

CREATE TABLE producto (
id_producto INT AUTO_INCREMENT PRIMARY KEY,
nombre VARCHAR(50),
precio DECIMAL(10,2),
categoria_id INT,
FOREIGN KEY (categoria_id) REFERENCES categoria(id_categoria)
);

CREATE TABLE factura (
id_factura INT AUTO_INCREMENT PRIMARY KEY,
fecha DATE,
persona_id INT,
usuario_id INT,
FOREIGN KEY (persona_id) REFERENCES persona(id_persona),
FOREIGN KEY (usuario_id) REFERENCES usuario(id_usuario)
);

CREATE TABLE detalle_factura (
id_detalle INT AUTO_INCREMENT PRIMARY KEY,
cantidad INT,
factura_id INT,
producto_id INT,
FOREIGN KEY (factura_id) REFERENCES factura(id_factura),
FOREIGN KEY (producto_id) REFERENCES producto(id_producto)
);

