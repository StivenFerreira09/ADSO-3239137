-- =========================
-- INNER JOIN
-- =========================

-- 1
SELECT f.id_factura, p.nombre, u.username
FROM factura f
INNER JOIN persona p ON f.persona_id = p.id_persona
INNER JOIN usuario u ON f.usuario_id = u.id_usuario;

-- 2
SELECT df.id_detalle, pr.nombre, df.cantidad
FROM detalle_factura df
INNER JOIN producto pr ON df.producto_id = pr.id_producto;
